# ─────────────────────────────────────────────
#  NEXUS BACKEND — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────
# Option 1: PostgreSQL (Neon / Supabase / Railway — FREE tiers available)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus_db?schema=public"

# Option 2: SQLite (local dev only — zero setup)
# DATABASE_URL="file:./dev.db"

# ── JWT Auth ────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────
# Your frontend URL (Vercel / localhost)
CLIENT_URL=http://localhost:5173

# ── Optional: Email (for password reset) ────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
